# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ─── Environment Variables / Secrets ─────────────────────────────────────────
.env
.env.*
*.env
!.env.example

# ─── Firebase & Google Cloud Credentials ─────────────────────────────────────
# NEVER commit service account keys!
serviceAccountKey.json
*serviceAccount*.json
*service_account*.json
firebase-adminsdk*.json
google-credentials.json
google-services.json

# ─── SQLite Database ──────────────────────────────────────────────────────────
# Only match specific SQLite/DB file extensions — NOT directory names like models/
instance/
*.db
*.sqlite
*.sqlite3
# The SQLite file in instance/ is named database.models — match it specifically
instance/database.models

# ─── ML Model Binaries ────────────────────────────────────────────────────────
# Trained model files are large binaries — store via Git LFS or DVC instead
ml_models/*.joblib
ml_models/*.pkl
ml_models/*.h5
ml_models/*.pt
ml_models/*.pth
ml_models/*.onnx
ml_models/*.bin

# ─── Uploaded Files ───────────────────────────────────────────────────────────
uploads/
# Keep the folder structure but not the uploaded content
!uploads/.gitkeep
!uploads/medical_records/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ─── OS Artifacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDEs & Editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── Distribution / Packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
site-packages/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/

# ─── Testing & Coverage ───────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.coveragerc
htmlcov/
.pytest_cache/
nosetests.xml
test-results/

# ─── Type Checkers ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ─── Flask Specific ───────────────────────────────────────────────────────────
flask_session/
